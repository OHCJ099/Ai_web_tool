{
  "manifest_version": 3,
  "name": "AI Selection Helper (AI 网页选择助手)",
  "version": "1.0.0",
  "description": "选中网页文本，右键或点击悬浮按钮，直接在网页内弹出 AI 答案，支持 Gemini/DeepSeek/OpenAI。",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js", "auto-answer.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "trigger-ai": {
      "suggested_key": {
        "default": "Ctrl+Shift+A",
        "mac": "Command+Shift+A"
      },
      "description": "使用 AI 联网解析选中文本"
    },
    "trigger-local-search": {
      "suggested_key": {
        "default": "Ctrl+Shift+Q",
        "mac": "Command+Shift+Q"
      },
      "description": "仅在本地题库中检索选中文本"
    },
    "toggle-auto-answer": {
      "suggested_key": {
        "default": "Alt+C",
        "mac": "Alt+C"
      },
      "description": "启动/继续自动答题"
    },
    "stop-auto-answer": {
      "suggested_key": {
        "default": "Alt+V",
        "mac": "Alt+V"
      },
      "description": "停止自动答题"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["content.css", "questions.json"],
      "matches": ["<all_urls>"]
    }
  ]
}